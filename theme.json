{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,

    "color": {
      "palette": [
        {
          "name": "Primary",
          "slug": "primary",
          "color": "#1A3C6E"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#F4A726"
        },
        {
          "name": "Light",
          "slug": "light",
          "color": "#F8F9FA"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#1A1A2E"
        },
        {
          "name": "Success",
          "slug": "success",
          "color": "#E8F4EC"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#FFFFFF"
        },
        {
          "name": "Surface",
          "slug": "surface",
          "color": "#F3F4F5"
        },
        {
          "name": "On Surface Variant",
          "slug": "on-surface-variant",
          "color": "#43474F"
        },
        {
          "name": "Error",
          "slug": "error",
          "color": "#BA1A1A"
        }
      ],
      "gradients": [
        {
          "name": "Hero Navy",
          "slug": "hero-navy",
          "gradient": "linear-gradient(135deg, #1A3C6E 0%, #1A1A2E 100%)"
        }
      ],
      "custom": false,
      "customGradient": false,
      "duotone": []
    },

    "typography": {
      "fontFamilies": [
        {
          "name": "Inter",
          "slug": "inter",
          "fontFamily": "Inter, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/Inter-Regular.woff2" ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "500",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/Inter-Medium.woff2" ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "600",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/Inter-SemiBold.woff2" ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "700",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/Inter-Bold.woff2" ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "800",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/Inter-ExtraBold.woff2" ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "name": "Small",   "slug": "small",   "size": "14px" },
        { "name": "Body",    "slug": "body",    "size": "16px" },
        { "name": "Medium",  "slug": "medium",  "size": "18px" },
        { "name": "H4",      "slug": "h4",      "size": "20px" },
        { "name": "H3",      "slug": "h3",      "size": "24px" },
        { "name": "H2",      "slug": "h2",      "size": "32px" },
        { "name": "H1",      "slug": "h1",      "size": "40px" },
        { "name": "Display", "slug": "display", "size": "48px" }
      ],
      "customFontSize": false,
      "dropCap": false
    },

    "spacing": {
      "spacingSizes": [
        { "name": "1",  "slug": "1",  "size": "8px"  },
        { "name": "2",  "slug": "2",  "size": "16px" },
        { "name": "3",  "slug": "3",  "size": "24px" },
        { "name": "4",  "slug": "4",  "size": "32px" },
        { "name": "6",  "slug": "6",  "size": "48px" },
        { "name": "8",  "slug": "8",  "size": "64px" },
        { "name": "12", "slug": "12", "size": "96px" }
      ],
      "padding": true,
      "margin": true,
      "customSpacingSize": false,
      "units": ["px", "em", "rem", "%", "vw", "vh"]
    },

    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },

    "shadow": {
      "presets": [
        {
          "name": "Card",
          "slug": "card",
          "shadow": "0 2px 8px rgba(0,0,0,0.08)"
        },
        {
          "name": "Card Hover",
          "slug": "card-hover",
          "shadow": "0 8px 32px rgba(26,60,110,0.08)"
        },
        {
          "name": "Enrol Card",
          "slug": "enrol-card",
          "shadow": "0 20px 50px rgba(0,0,0,0.15)"
        }
      ],
      "custom": false
    },

    "layout": {
      "contentSize": "1280px",
      "wideSize": "1280px"
    },

    "blocks": {
      "core/button": {
        "border": {
          "radius": true
        }
      }
    }
  },

  "styles": {
    "color": {
      "background": "var(--wp--preset--color--light)",
      "text": "#191C1D"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--body)",
      "fontWeight": "400",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--4)"
    },

    "elements": {
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "500",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h2)",
          "fontWeight": "500",
          "lineHeight": "1.25"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h3)",
          "fontWeight": "500",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h4)",
          "fontWeight": "500"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--primary)"
        },
        "typography": {
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--body)"
        },
        "border": {
          "radius": "8px"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--2)",
            "bottom": "var(--wp--preset--spacing--2)",
            "left": "var(--wp--preset--spacing--4)",
            "right": "var(--wp--preset--spacing--4)"
          }
        }
      }
    },

    "blocks": {
      "core/group": {
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--8)",
            "bottom": "var(--wp--preset--spacing--8)"
          }
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "500",
          "fontSize": "var(--wp--preset--font-size--body)"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "500"
        }
      },
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--on-surface-variant)"
        },
        "border": {
          "color": "var(--wp--preset--color--on-surface-variant)",
          "width": "1px"
        }
      }
    }
  },

  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],

  "customTemplates": [
    { "name": "front-page",    "title": "Front Page",    "postTypes": ["page"] },
    { "name": "page-about",    "title": "About Page",    "postTypes": ["page"] },
    { "name": "page-contact",  "title": "Contact Page",  "postTypes": ["page"] },
    { "name": "page-hot-deals","title": "Hot Deals",     "postTypes": ["page"] },
    { "name": "page-login",    "title": "Login Page",    "postTypes": ["page"] }
  ]
}